generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  credits       Int       @default(5)

  accounts         Account[]
  sessions         Session[]
  projects         Project[]
  gscConnections   GscConnection[]
  creditTransactions CreditTransaction[]
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  balance     Int
  type        String   // welcome | use | purchase | grant
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  country   String?
  language  String?  @default("en")
  domain    String?
  niche     String?
  status    String   @default("pending") // pending | generating | enriching | ready | error
  errorMsg  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crawlStatus  String?  // null | crawling | crawled | crawl-error

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes        ClusterNode[]
  links        LinkSuggestion[]
  missingNodes MissingNode[]
  serpData     SerpData[]
  crawledPages CrawledPage[]
  gscQueries   GscQueryData[]

  @@index([userId])
}

model ClusterNode {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  slug          String
  role          String   // pillar | sub-pillar | support | comparison | list | informational
  groupName     String?
  parentId      String?
  sortOrder     Int      @default(0)
  priorityScore Float    @default(0)
  publishOrder  Int      @default(0)
  centrality    Float    @default(0)
  supportValue  Float    @default(0)
  opportunity   Float    @default(0)
  ease          Float    @default(0)
  serpClarity   Float    @default(0)
  targetKeyword  String?
  searchIntent   String?  // informational | commercial | transactional | navigational
  notes          String?
  realVolume     Int?
  realDifficulty Float?
  realCpc        Float?
  dataSource     String?  // dataforseo | gsc | ai-estimated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        ClusterNode?   @relation("NodeHierarchy", fields: [parentId], references: [id])
  children      ClusterNode[]  @relation("NodeHierarchy")
  outgoingLinks LinkSuggestion[] @relation("LinkSource")
  incomingLinks LinkSuggestion[] @relation("LinkTarget")

  @@index([projectId])
}

model LinkSuggestion {
  id         String @id @default(cuid())
  projectId  String
  sourceId   String
  targetId   String
  anchorText String
  context    String?
  linkType   String @default("contextual") // contextual | navigational | related-reading

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  ClusterNode @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  ClusterNode @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model MissingNode {
  id              String @id @default(cuid())
  projectId       String
  suggestedTitle  String
  suggestedRole   String
  reason          String
  confidenceScore Float  @default(0.5)
  parentNodeId    String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model SerpData {
  id           String   @id @default(cuid())
  projectId    String
  keyword      String
  volume       Int?
  difficulty   Float?
  cpc          Float?
  competition  Float?
  intent       String?
  serpFeatures String?  // JSON string
  topResults   String?  // JSON string
  fetchedAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, keyword])
  @@index([projectId])
}

model CrawledPage {
  id              String   @id @default(cuid())
  projectId       String
  url             String
  path            String
  title           String?
  metaDescription String?
  h1              String?
  headings        String?  // JSON array of h2s
  wordCount       Int?
  matchedNodeId   String?
  crawledAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, url])
  @@index([projectId])
}

model GscConnection {
  id           String   @id @default(cuid())
  userId       String
  propertyUrl  String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyUrl])
  @@index([userId])
}

model GscQueryData {
  id          String   @id @default(cuid())
  projectId   String
  query       String
  impressions Int
  clicks      Int
  ctr         Float
  position    Float
  fetchedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, query])
  @@index([projectId])
}

model AppSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}
